# Applicattion
NODE_ENV=development
PORT=8080
API_SECRET_KEY="secret_key_goes_here" 

# Database  
DATABASE_URL=postgresql://crm_user:crm_password@db:5432/crm_db

# PostgreSQL
POSTGRES_USER="crm_user"
POSTGRES_PASSWORD="crm_password"
POSTGRES_DB="crm_db"

# Meta / WhatsApp Business API 
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_WEBHOOK_VERIFY_TOKEN="token_goes_here"
META_API_VERSION=v19.0

# Hot notifications
META_OWNER_PHONE=

# Google Maps api
GOOGLE_MAPS_API_KEY=

# API CNPJ
CNPJ_API_URL=https://brasilapi.com.br/api/cnpj/v1
CNPJ_API_FALLBACK_URL=https://receitaws.com.br/v1/cnpj

# Queue / Worker 
DEAD_LETTER_ALERT_HOURS=4
QUEUE_BATCH_SIZE=5

# Frequency Cap 
FREQUENCY_CAP_DAYS=7
FREQUENCY_CAP_MAX_30D=3 # Maximum campaigns per contact in 30 days

# Score 
SCORE_MAX=100
SCORE_DECAY_FACTOR=0.85 # Weekly decay factor applied by the cron POST /contacts/decay-scores